{
  "name": "data-manage",
  "version": "1.0.0",
  "main": "main.js",
  "description": "Aplikasi transfer Data - Local & Cloud",
  "author": "Think",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.Think.flow",
    "productName": "Think Flow",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist/**",
      "!node_modules/**/.cache",
      "!**/*.map"
    ],
    "win": {
      "icon": "img/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Think Flow"
    },
    "portable": {
      "artifactName": "${productName} Portable.exe"
    }
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.9.0"
  },
  "keywords": [],
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "peer": "^0.6.1"
  }
}
